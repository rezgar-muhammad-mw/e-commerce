{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "es2021",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "strictPropertyInitialization": false,
    "lib": ["es2022"],
    "paths": {
      "@org/shared": ["../../libs/shared/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts"]
}
